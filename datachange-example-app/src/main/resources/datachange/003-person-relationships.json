{
  "specVersion": "1.0",
  "id": "person-relationships-003",
  "author": "example",
  "description": "Create Person with OneToOne profile and OneToMany dependents",
  "labels": ["demo", "relations"],
  "tags": ["one-to-one", "one-to-many", "many-to-one"],
  "transactionMode": "CHANGESET",
  "preConditions": {
    "expression": "not exists(Person where firstName='Max')"
  },
  "changes": [
    {
      "id": "insert-person",
      "op": "insert",
      "entity": "Person",
      "values": {
        "firstName": "Max",
        "lastName": "Mustermann",
        "age": 34
      },
      "saveAs": "person"
    },
    {
      "id": "insert-profile",
      "op": "insert",
      "entity": "PersonProfile",
      "values": {
        "preferredLanguage": "de",
        "person": "${ref('person')}"
      }
    },
    {
      "id": "insert-address-home",
      "op": "insert",
      "entity": "Address",
      "values": {
        "street": "Hauptstrasse 1",
        "city": "Hamburg",
        "person": "${ref('person')}"
      },
      "saveAs": "homeAddress"
    },
    {
      "id": "insert-address-office",
      "op": "insert",
      "entity": "Address",
      "values": {
        "street": "Kontorweg 10",
        "city": "Hamburg",
        "person": "${ref('person')}"
      }
    },
    {
      "id": "insert-bank-main",
      "op": "insert",
      "entity": "BankAccount",
      "values": {
        "iban": "DE02120300000000202051",
        "bic": "BYLADEM1001",
        "person": "${ref('person')}"
      }
    },
    {
      "id": "update-home-address-city",
      "op": "update",
      "entity": "Address",
      "where": "street == 'Hauptstrasse 1'",
      "set": {
        "city": "Berlin"
      }
    }
  ]
}
